# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=123456:your_telegram_bot_token_here
ADMIN_IDS=111111111,222222222

# ── Monobank Personal API ────────────────────────────────────────────────────
MONO_TOKEN=your_monobank_personal_token
MONO_JAR_SEND_ID=jar/XXXXXXXXXX
MONO_WEBHOOK_SECRET=generate_random_secret_here

# ── Webhook ──────────────────────────────────────────────────────────────────
# Публічний HTTPS-URL (VPS / Cloudflare Tunnel / ngrok)
WEBHOOK_BASE_URL=https://your-public-domain.example.com
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Час життя коду оплати, годин
PAYMENT_CODE_TTL_HOURS=24

# ── PostgreSQL (для docker-compose) ──────────────────────────────────────────
POSTGRES_USER=uaanisub
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=uaanisub

# DATABASE_URL використовується тільки при локальному запуску (без docker).
# У docker-compose значення береться з POSTGRES_* вище та автоматично
# перезаписується на host=postgres.
DATABASE_URL=postgresql://uaanisub:change_me_strong_password@localhost:123/uaanisub
